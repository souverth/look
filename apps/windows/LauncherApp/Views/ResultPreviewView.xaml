<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LauncherApp.Views.ResultPreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="48"
                    Height="48"
                    Margin="0,0,10,0"
                    CornerRadius="10"
                    Background="#223044"
                    VerticalAlignment="Center">
                    <Grid>
                        <TextBlock
                            x:Name="GlyphBlock"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource LauncherSecondaryTextBrush}"
                            Text="&#xE8A5;" />
                        <Image
                            x:Name="HeaderImage"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock
                        x:Name="TitleBlock"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LauncherTextBrush}"
                        Text="Preview"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel
                        x:Name="HeaderMetaRow"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Border
                            Background="#2D4770"
                            CornerRadius="9"
                            Padding="7,2">
                            <TextBlock
                                x:Name="HeaderKindBadge"
                                Foreground="White"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Text="App" />
                        </Border>
                        <TextBlock
                            x:Name="HeaderSizeText"
                            FontSize="11"
                            Foreground="{StaticResource LauncherSecondaryTextBrush}"
                            VerticalAlignment="Center"
                            Text="Size" />
                    </StackPanel>
                    <TextBlock
                        x:Name="SubtitleBlock"
                        FontSize="11"
                        Foreground="{StaticResource LauncherSecondaryTextBrush}"
                        Text="Select a result to view details"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="0,14,0,0">
                <StackPanel Spacing="10">
                    <StackPanel x:Name="StandardPanel" Spacing="10">
                        <Image
                            x:Name="FilePreviewImage"
                            MaxHeight="180"
                            Stretch="Uniform"
                            Visibility="Collapsed" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" Text="Version" />
                            <TextBlock
                                x:Name="VersionText"
                                Grid.Column="1"
                                FontSize="12"
                                Foreground="{StaticResource LauncherTextBrush}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" Text="Path" />
                            <TextBlock
                                x:Name="PathText"
                                Grid.Column="1"
                                FontSize="12"
                                Foreground="{StaticResource LauncherTextBrush}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" Text="Modified" />
                            <TextBlock
                                x:Name="ModifiedText"
                                Grid.Column="1"
                                FontSize="12"
                                Foreground="{StaticResource LauncherTextBrush}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="ClipboardPanel" Spacing="10" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="ClipboardCapturedText"
                                FontSize="11"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource LauncherMutedTextBrush}"
                                Text="Captured" />
                            <Button
                                x:Name="ClipboardDeleteButton"
                                Grid.Column="1"
                                Padding="10,5"
                                MinWidth="0"
                                MinHeight="0"
                                Background="#2A1117"
                                BorderBrush="#71414D"
                                BorderThickness="1"
                                CornerRadius="14"
                                Click="ClipboardDeleteButton_OnClick"
                                ToolTipService.ToolTip="Delete this clipboard entry">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="12"
                                        Foreground="#FF8AA3"
                                        VerticalAlignment="Center"
                                        Text="&#xE74D;" />
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#FF8AA3"
                                        VerticalAlignment="Center"
                                        Text="Delete" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock
                                x:Name="ClipboardCharsText"
                                FontSize="12"
                                Foreground="{StaticResource LauncherTextBrush}"
                                Text="0 chars" />
                            <TextBlock
                                x:Name="ClipboardLinesText"
                                FontSize="12"
                                Foreground="{StaticResource LauncherTextBrush}"
                                Text="0 lines" />
                        </StackPanel>

                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource LauncherMutedTextBrush}"
                            Text="Preview" />

                        <Border
                            Background="{StaticResource LauncherPanelAltBrush}"
                            CornerRadius="8"
                            Padding="10">
                            <ScrollViewer MaxHeight="220">
                                <TextBlock
                                    x:Name="ClipboardContentText"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="{StaticResource LauncherTextBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
</UserControl>
