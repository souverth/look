<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LauncherApp.Views.HelpScreenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:LauncherApp.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="12" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="Keyboard Help" />
                <TextBlock
                    Grid.Column="1"
                    FontSize="12"
                    Foreground="{StaticResource LauncherMutedTextBrush}"
                    Text="Ctrl+H to close" />
            </Grid>

            <TextBlock
                FontSize="13"
                Foreground="{StaticResource LauncherMutedTextBrush}"
                Text="Quick guide for app list, clipboard search, and command flow."
                TextWrapping="Wrap" />

            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="Main" />

                <StackPanel Spacing="6">
                    <views:KeyChordRowView KeyText="Enter" Description="Open selected app/file/folder or copy selected clipboard item" />
                    <views:KeyChordRowView KeyText="Ctrl+C" Description="Copy selected file/folder to pasteboard" />
                    <views:KeyChordRowView KeyText="Ctrl+P" Description="Pick selected file/folder (toggle); paste in Explorer to copy all picks" />
                    <views:KeyChordRowView KeyText="Ctrl+Shift+P" Description="Clear all picked items" />
                    <views:KeyChordRowView KeyText="Tab / Shift+Tab" Description="Move selection" />
                    <views:KeyChordRowView KeyText="Up / Down" Description="Move selection" />
                    <views:KeyChordRowView KeyText="Ctrl+F" Description="Reveal selected app/file/folder in Explorer" />
                    <views:KeyChordRowView KeyText="Ctrl+Enter" Description="Search current query on Google" />
                    <views:KeyChordRowView KeyText="Ctrl+/" Description="Enter command mode" />
                    <views:KeyChordRowView KeyText=":cmd" Description="Quick-access command from home screen (e.g. :calc 2+2, :kill chrome, :sys)" />
                    <views:KeyChordRowView KeyText="Ctrl+H" Description="Toggle this help screen" />
                    <views:KeyChordRowView KeyText="Esc" Description="Close help / back / hide launcher" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="Query prefixes" />

                <StackPanel Spacing="6">
                    <views:KeyChordRowView KeyText="a&quot;word" Description="Apps only" />
                    <views:KeyChordRowView KeyText="f&quot;word" Description="Files only" />
                    <views:KeyChordRowView KeyText="d&quot;word" Description="Folders only" />
                    <views:KeyChordRowView KeyText="r&quot;pattern" Description="Regex search" />
                    <views:KeyChordRowView KeyText="c&quot;word" Description="Clipboard history search (latest 10 text clips)" />
                    <views:KeyChordRowView KeyText="t&quot;word" Description="Web translate (VI/EN/JA)" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="Command mode" />

                <StackPanel Spacing="6">
                    <views:KeyChordRowView KeyText="Ctrl+1 / Ctrl+2 / Ctrl+3" Description="Switch command" KeyColumnWidth="140" />
                    <views:KeyChordRowView KeyText="Up / Down" Description="Switch command" KeyColumnWidth="140" />
                    <views:KeyChordRowView KeyText="Enter" Description="Run command" KeyColumnWidth="140" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
