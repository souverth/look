<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LauncherApp.Views.Settings.Tabs.AdvancedSettingsTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:LauncherApp.Views"
    xmlns:services="using:LauncherApp.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="8,4,8,8" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LauncherTextBrush}" Text="Background" />
            <Border Style="{StaticResource LauncherSurfaceBorderStyle}" Padding="12">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource LauncherSecondaryButtonStyle}" Content="Choose Background Image" Click="ChooseBackgroundImageButton_OnClick" />
                        <Button Style="{StaticResource LauncherSecondaryButtonStyle}" Content="Clear" Click="ClearBackgroundImageButton_OnClick" />
                    </StackPanel>

                    <TextBlock x:Name="BackgroundImagePathText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="No image selected" TextWrapping="NoWrap" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" Text="Image Layout" />
                        <ComboBox x:Name="BackgroundImageModeCombo" Grid.Column="1" SelectedIndex="1">
                            <ComboBoxItem Content="Center" Tag="fit" />
                            <ComboBoxItem Content="Fill" Tag="fill" />
                            <ComboBoxItem Content="Stretch" Tag="stretch" />
                            <ComboBoxItem Content="Duplicate" Tag="tile" />
                        </ComboBox>
                        <TextBlock Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="How image is placed in launcher background." />
                    </Grid>

                    <views:LabeledSliderView x:Name="BackgroundImageOpacitySlider" Label="Image Opacity" LabelColumnWidth="150" Minimum="0" Maximum="100" StepFrequency="1" Value="35" />
                    <views:LabeledSliderView x:Name="BackgroundImageBlurSlider" Label="Image Blur" LabelColumnWidth="150" Minimum="0" Maximum="30" StepFrequency="1" Value="8" />
                </StackPanel>
            </Border>

            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LauncherTextBrush}" Text="Indexing" />
            <Border Style="{StaticResource LauncherSurfaceBorderStyle}" Padding="12">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" Text="File Scan Depth" />
                        <NumberBox x:Name="FileScanDepthBox" Grid.Column="1" Value="4" Minimum="1" Maximum="12" SpinButtonPlacementMode="Inline" />
                        <TextBlock Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="How many directory levels to index." />
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" Text="File Scan Limit" />
                        <NumberBox x:Name="FileScanLimitBox" Grid.Column="1" Value="8000" Minimum="500" Maximum="50000" SpinButtonPlacementMode="Inline" />
                        <TextBlock Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="Max files indexed per refresh." />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Foreground="{StaticResource LauncherTextBrush}" Text="Lazy indexing" />
                            <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="Refresh index automatically when launcher opens after file/app changes." />
                        </StackPanel>
                        <ToggleSwitch x:Name="LazyIndexingToggle" Grid.Column="1" IsOn="True" OnContent="On" OffContent="Off" />
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Top" Foreground="{StaticResource LauncherMutedTextBrush}" Text="Detected Drives" />
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Other fixed drives found on this PC. Tick a drive to include it in the index (saved with Save)." />
                            <ItemsControl x:Name="DetectedDrivesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:CandidateDrive">
                                        <Border Padding="10,5" Background="{StaticResource LauncherPanelAltBrush}" CornerRadius="12">
                                            <CheckBox Click="DetectedDriveCheckbox_OnClick"
                                                      Tag="{x:Bind DriveLetter}"
                                                      IsChecked="{x:Bind IsSelected}"
                                                      Content="{x:Bind DisplayLabel}"
                                                      Foreground="{StaticResource LauncherTextBrush}"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="DetectedDrivesEmptyText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="No additional drives detected." />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Top" Foreground="{StaticResource LauncherMutedTextBrush}" Text="Extra Scan Dirs" />
                        <StackPanel Grid.Column="1" Spacing="6">
                            <Button Style="{StaticResource LauncherSecondaryButtonStyle}" Width="120" HorizontalAlignment="Left" Content="Add Folder" Click="AddScanRootButton_OnClick" />
                            <TextBlock x:Name="ScanRootsNoticeText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Visibility="Collapsed" TextWrapping="Wrap" />
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                <ItemsControl x:Name="ScanRootsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="10,5" Background="{StaticResource LauncherPanelAltBrush}" CornerRadius="12" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind}" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource LauncherTextBrush}" />
                                                <Button Grid.Column="1"
                                                        Click="ScanRootRemove_OnClick"
                                                        Tag="{x:Bind}"
                                                        Width="22" Height="22" Padding="0"
                                                        Background="Transparent" BorderThickness="0">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE894;" Foreground="{StaticResource LauncherMutedTextBrush}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="ScanRootsEmptyText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="No extra scan directories yet" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Top" Foreground="{StaticResource LauncherMutedTextBrush}" Text="Skip Folders" />
                        <StackPanel Grid.Column="1" Spacing="6">
                            <Button Style="{StaticResource LauncherSecondaryButtonStyle}" Width="120" HorizontalAlignment="Left" Content="Add Folder" Click="AddExcludedFolderButton_OnClick" />
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                <ItemsControl x:Name="ExcludedFoldersList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="10,5" Background="{StaticResource LauncherPanelAltBrush}" CornerRadius="12" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind}" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource LauncherTextBrush}" />
                                                <Button Grid.Column="1"
                                                        Click="ExcludedFolderRemove_OnClick"
                                                        Tag="{x:Bind}"
                                                        Width="22" Height="22" Padding="0"
                                                        Background="Transparent" BorderThickness="0">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE894;" Foreground="{StaticResource LauncherMutedTextBrush}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="ExcludedFoldersEmptyText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="No excluded folder paths yet" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LauncherTextBrush}" Text="Privacy &amp; Logs" />
            <Border Style="{StaticResource LauncherSurfaceBorderStyle}" Padding="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" Text="Backend Log Level" />
                    <ComboBox x:Name="BackendLogLevelCombo" Grid.Column="1" SelectedIndex="0">
                        <ComboBoxItem Content="Error" Tag="error" />
                        <ComboBoxItem Content="Info" Tag="info" />
                        <ComboBoxItem Content="Debug" Tag="debug" />
                    </ComboBox>
                    <TextBlock Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="Error only by default; use Info/Debug for troubleshooting." />
                </Grid>
            </Border>

            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LauncherTextBrush}" Text="Startup" />
            <Border Style="{StaticResource LauncherSurfaceBorderStyle}" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Foreground="{StaticResource LauncherTextBrush}" Text="Launch at login" />
                        <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" Text="Start look automatically when you sign in." />
                    </StackPanel>
                    <!-- Default off: AdvancedSettingsTabView.xaml.cs only overrides this
                         when launch_at_login is present and parseable, so a fresh/default
                         config (which omits the key) would otherwise show "On" in the UI
                         and silently write launch_at_login=true on the next save,
                         enabling startup the user never asked for. -->
                    <ToggleSwitch x:Name="LaunchAtLoginToggle" Grid.Column="1" IsOn="False" OnContent="On" OffContent="Off" />
                </Grid>
            </Border>

            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LauncherTextBrush}" Text="Config file" />
            <Border Style="{StaticResource LauncherSurfaceBorderStyle}" Padding="12">
                <StackPanel Spacing="8">
                    <Button Style="{StaticResource LauncherDangerButtonStyle}" Width="170" HorizontalAlignment="Left" Content="Create Fresh Config" Click="CreateFreshConfigButton_OnClick" />
                    <TextBlock Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" TextWrapping="Wrap" Text="Regenerate a fresh default config file. Your current file will be replaced." />
                    <TextBlock x:Name="FreshConfigStatusText" Foreground="{StaticResource LauncherMutedTextBrush}" FontSize="11" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
