<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LauncherApp.Views.LauncherResultRowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="0">
        <Grid Padding="10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="PickedCheck"
                Grid.Column="0"
                Width="14"
                Margin="0,0,8,0"
                FontFamily="Segoe MDL2 Assets"
                FontSize="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{StaticResource LauncherAccentBrush}"
                Text="&#xE73E;"
                Visibility="Collapsed" />

            <Border
                Grid.Column="1"
                Width="32"
                Height="32"
                Margin="0,0,10,0"
                VerticalAlignment="Center">
                <Grid>
                    <Image
                        x:Name="IconImage"
                        Width="32"
                        Height="32"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="IconGlyph"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource LauncherMutedTextBrush}" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" Spacing="2">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="{Binding Title}"
                    TextTrimming="CharacterEllipsis" />
                <!-- Meta line (kind + path / subtitle). Uses the muted tier brush which,
                     when a preset is active, carries the theme's signature textMuted
                     token (e.g. Tokyo Night's blue-grey #8FA3C7). Mirrors macOS
                     LauncherRowView's foregroundStyle(themeStore.mutedTextColor()). -->
                <TextBlock
                    FontSize="11"
                    Foreground="{StaticResource LauncherMutedTextBrush}"
                    Text="{Binding MetaLabel}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <Rectangle
            Height="1"
            Margin="6,0,6,0"
            Fill="{StaticResource LauncherBorderBrush}"
            Opacity="0.75" />
    </StackPanel>
</UserControl>