<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LauncherApp.Views.TranslatePanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:LauncherApp.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="14" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock
                    FontSize="11"
                    Foreground="{StaticResource LauncherMutedTextBrush}"
                    Text="Translate" />
                <TextBlock
                    x:Name="OriginalText"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherTextBrush}"
                    Text="Type text after t&quot;"
                    TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock
                x:Name="StatusText"
                Grid.Column="1"
                FontSize="11"
                VerticalAlignment="Center"
                Foreground="{StaticResource LauncherMutedTextBrush}"
                Text="" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <views:TranslateLanguageSectionView x:Name="ViSection" Label="TIẾNG VIỆT" />
                <views:TranslateLanguageSectionView x:Name="EnSection" Label="ENGLISH" />
                <views:TranslateLanguageSectionView x:Name="JaSection" Label="日本語" />
            </StackPanel>
        </ScrollViewer>

        <Button
            x:Name="OpenInBrowserButton"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            Padding="12,8"
            Background="{StaticResource LauncherPanelAltBrush}"
            BorderBrush="{StaticResource LauncherBorderBrush}"
            BorderThickness="1"
            Foreground="{StaticResource LauncherAccentBrush}"
            Click="OpenInBrowserButton_Click"
            Visibility="Collapsed">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    Foreground="{StaticResource LauncherAccentBrush}"
                    VerticalAlignment="Center"
                    Text="&#xE774;" />
                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource LauncherAccentBrush}"
                    VerticalAlignment="Center"
                    Text="Open in Google Translate" />
                <TextBlock
                    Grid.Column="2"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="11"
                    Foreground="{StaticResource LauncherAccentBrush}"
                    VerticalAlignment="Center"
                    Text="&#xE8A7;" />
            </Grid>
        </Button>
    </Grid>
</UserControl>
