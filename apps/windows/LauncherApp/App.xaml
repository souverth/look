<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="LauncherApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LauncherApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="LauncherColorBg">#0E1218</Color>
            <Color x:Key="LauncherColorPanel">#2D151C26</Color>
            <Color x:Key="LauncherColorPanelAlt">#451A2330</Color>
            <Color x:Key="LauncherColorText">#E8EDF7</Color>
            <Color x:Key="LauncherColorSecondary">#BEC3CB</Color>
            <Color x:Key="LauncherColorMuted">#A2AEBD</Color>
            <Color x:Key="LauncherColorBorder">#66273446</Color>
            <Color x:Key="LauncherColorAccent">#7AA2F7</Color>
            <Color x:Key="LauncherColorSuccess">#1F8B4C</Color>
            <Color x:Key="LauncherColorInfo">#2E5EA8</Color>
            <Color x:Key="LauncherColorWarning">#A36E1C</Color>
            <Color x:Key="LauncherColorError">#A03333</Color>

            <SolidColorBrush x:Key="LauncherBgBrush" Color="{StaticResource LauncherColorBg}" />
            <SolidColorBrush x:Key="LauncherTransparentBrush" Color="Transparent" />
            <SolidColorBrush x:Key="LauncherPanelBrush" Color="{StaticResource LauncherColorPanel}" />
            <SolidColorBrush x:Key="LauncherPanelAltBrush" Color="{StaticResource LauncherColorPanelAlt}" />
            <SolidColorBrush x:Key="LauncherTextBrush" Color="{StaticResource LauncherColorText}" />
            <SolidColorBrush x:Key="LauncherSecondaryTextBrush" Color="{StaticResource LauncherColorSecondary}" />
            <SolidColorBrush x:Key="LauncherMutedTextBrush" Color="{StaticResource LauncherColorMuted}" />
            <SolidColorBrush x:Key="LauncherBorderBrush" Color="{StaticResource LauncherColorBorder}" />
            <SolidColorBrush x:Key="LauncherAccentBrush" Color="{StaticResource LauncherColorAccent}" />
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="LauncherBannerSuccessBrush" Color="{StaticResource LauncherColorSuccess}" />
            <SolidColorBrush x:Key="LauncherBannerInfoBrush" Color="{StaticResource LauncherColorInfo}" />
            <SolidColorBrush x:Key="LauncherBannerWarningBrush" Color="{StaticResource LauncherColorWarning}" />
            <SolidColorBrush x:Key="LauncherBannerErrorBrush" Color="{StaticResource LauncherColorError}" />

            <x:Double x:Key="LauncherRadiusSm">8</x:Double>
            <x:Double x:Key="LauncherRadiusMd">12</x:Double>
            <x:Double x:Key="LauncherRadiusLg">16</x:Double>
            <Thickness x:Key="LauncherBorderThickness">1.5</Thickness>

            <Style x:Key="LauncherBodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="LauncherSubtitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LauncherBodyTextStyle}">
                <Setter Property="Foreground" Value="{StaticResource LauncherSecondaryTextBrush}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="LauncherCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LauncherBodyTextStyle}">
                <Setter Property="Foreground" Value="{StaticResource LauncherMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="LauncherPrimaryButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}" />
                <Setter Property="Background" Value="{StaticResource LauncherAccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource LauncherAccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <Style x:Key="LauncherSecondaryButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}" />
                <Setter Property="Background" Value="{StaticResource LauncherPanelAltBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <Style x:Key="LauncherGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource LauncherSecondaryButtonStyle}">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Style x:Key="LauncherDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource LauncherSecondaryButtonStyle}">
                <Setter Property="Foreground" Value="#FFCBCB" />
                <Setter Property="BorderBrush" Value="#A44A4A" />
                <Setter Property="Background" Value="#2D1818" />
            </Style>

            <Style x:Key="LauncherSurfaceBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource LauncherPanelBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}" />
                <Setter Property="BorderThickness" Value="{ThemeResource LauncherBorderThickness}" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
