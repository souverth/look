{
  "app": {
    "security": {
      "assetProtocol": {
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$LOCALAPPDATA/**",
          "$PICTURE/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "/usr/share/**",
          "/nix/**",
          "/run/**",
          "/tmp/**"
        ]
      }
    }
  }
}
