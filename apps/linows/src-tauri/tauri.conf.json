{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "Look",
  "version": "0.5.1",
  "identifier": "com.look.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Look",
        "width": 860,
        "height": 580,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "resizable": false,
        "center": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$LOCALAPPDATA/**",
          "$PICTURE/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "/usr/share/**",
          "/nix/**",
          "/run/**",
          "/tmp/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Keyboard-first desktop launcher",
    "longDescription": "Look is a keyboard-first, local-first desktop launcher. Find and open apps, files, folders, clipboard history, and run quick commands without leaving the keyboard.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libsoup-3.0-0",
          "libglib2.0-0",
          "libcairo2",
          "libpango-1.0-0",
          "libgdk-pixbuf-2.0-0",
          "libharfbuzz0b",
          "libdbus-1-3",
          "libasound2",
          "xdg-desktop-portal"
        ],
        "section": "utils",
        "priority": "optional"
      }
    }
  },
  "plugins": {}
}
